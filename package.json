{
  "name": "foldercompare",
  "version": "1.0.0",
  "description": "Folder comparison tool for Windows 11 Enterprise. Electron desktop app (no local HTTP server).",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron electron/main.cjs",
    "start:electron": "electron electron/main.cjs",
    "dist": "electron-builder --win portable",
    "test": "node tests/engine.test.cjs",
    "postinstall": "install-electron"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamenianc/Comparer.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/iamenianc/Comparer/issues"
  },
  "homepage": "https://github.com/iamenianc/Comparer#readme",
  "dependencies": {
    "chokidar": "^5.0.0",
    "diff": "^9.0.0"
  },
  "devDependencies": {
    "electron": "42.5.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.comparer.app",
    "productName": "Comparer",
    "files": [
      "electron/**/*",
      "engine/**/*",
      "public/**/*"
    ],
    "win": {
      "target": "portable"
    },
    "portable": {
      "artifactName": "Comparer-${version}-portable.exe"
    }
  }
}
